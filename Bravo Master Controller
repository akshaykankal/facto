      "parameters": {
        "functionCode": "const transactions = $input.all();\nconst analysis = {\n  total_income: 0,\n  total_expenses: 0,\n  by_category: {},\n  by_company: {}\n};\n\ntransactions.forEach(t => {\n  const amount = parseFloat(t.json.amount);\n  const category = t.json.category;\n  const company = t.json.company || 'Personal';\n  \n  if (t.json.type === 'credit') {\n    analysis.total_income += amount;\n  } else {\n    analysis.total_expenses += amount;\n    \n    if (!analysis.by_category[category]) {\n      analysis.by_category[category] = 0;\n    }\n    analysis.by_category[category] += amount;\n  }\n  \n  if (!analysis.by_company[company]) {\n    analysis.by_company[company] = {income: 0, expenses: 0};\n  }\n  \n  if (t.json.type === 'credit') {\n    analysis.by_company[company].income += amount;\n  } else {\n    analysis.by_company[company].expenses += amount;\n  }\n});\n\nanalysis.net_profit = analysis.total_income - analysis.total_expenses;\nanalysis.savings_rate = (analysis.net_profit / analysis.total_income * 100).toFixed(2);\n\nreturn [{json: analysis}];"
      },
